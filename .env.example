# ────────────────────────────────────────────────────────────────────────────
# World Monitor — Variables de Entorno
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas .env a git.
# ────────────────────────────────────────────────────────────────────────────

# ── API Keys ──────────────────────────────────────────────────────────────────

# Federal Reserve Economic Data (FRED)
# Obtén tu key gratuita en: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=57c52dd034f1cfa12d4e642fa741871b

# Anthropic — Motor IA del Módulo 15
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NewsAPI — Noticias financieras
# Plan gratuito: 100 requests/día. Regístrate en: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here


# ── Base de Datos ─────────────────────────────────────────────────────────────

# Nombre del fichero SQLite (se crea en la raíz del proyecto)
DB_FILENAME=world_monitor.db


# ── Servidor Dash ─────────────────────────────────────────────────────────────

# Host donde escucha el dashboard (127.0.0.1 = solo local)
DASH_HOST=127.0.0.1

# Puerto del dashboard
DASH_PORT=8050

# Modo debug (true = recarga automática al editar código)
DASH_DEBUG=false
